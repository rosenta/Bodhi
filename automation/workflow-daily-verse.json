    {
      "parameters": {
        "method": "POST",
        "url": "https://app.publer.io/api/v1/posts",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"posts\": [\n    {\n      \"social_account_ids\": [\"{{ $env.PUBLER_IG_ACCOUNT_ID }}\"],\n      \"text\": {{ JSON.stringify($('Parse Content Variants').first().json.content.front_text + '\\n\\n' + $('Parse Content Variants').first().json.content.back_text) }},\n      \"scheduled_at\": \"{{ $now.set({ hour: 8, minute: 0 }).toISO() }}\",\n      \"media_type\": \"image\"\n    },\n    {\n      \"social_account_ids\": [\"{{ $env.PUBLER_TWITTER_ACCOUNT_ID }}\"],\n      \"text\": {{ JSON.stringify($('Parse Content Variants').first().json.content.front_text) }},\n      \"scheduled_at\": \"{{ $now.set({ hour: 10, minute: 0 }).toISO() }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "schedule-social",
